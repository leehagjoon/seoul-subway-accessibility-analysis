def clean_name_final(text):
    if pd.isna(text): return ""
    text = str(text)
    text = re.sub(r'\(.*\)', '', text)
    if text.endswith('역') and len(text) > 2:
        text = text[:-1]
    text = text.replace('환승', '')
    text = re.sub(r'[^가-힣a-zA-Z0-9]', '', text)
    return text.strip()

