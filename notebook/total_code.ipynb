    '구로디지털': '구로디지털단지'
})
# 층수 숫자화 함수
def parse_floor(x):
    x = str(x).strip().upper()
    if x == '' or x == 'NAN':
        return np.nan

    m = re.match(r'B(\d+)', x)
    if m:
        return int(m.group(1))

    m = re.match(r'(\d+)F', x)
    if m:
        return int(m.group(1))

    return np.nan

ops_raw['층수_num'] = ops_raw['층수'].apply(parse_floor)
# 역 단위로 집계
