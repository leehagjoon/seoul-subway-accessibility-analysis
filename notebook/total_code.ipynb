    items = [x.strip() for x in text.split(', ')]

    for item in items:
        m = re.match(r'(.+?)\((.+?)\)$', item)
        if m:
            station = m.group(1).strip()
            line = m.group(2).strip()
        else:
            station = item.strip()
            line = None

        rows.append([gu, station, line])

